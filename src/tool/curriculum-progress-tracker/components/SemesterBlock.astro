---
interface Props {
  addCourseButton: string;
  semesterNamePlaceholder: string;
  courseNamePlaceholder: string;
  creditsPlaceholder: string;
  gradePlaceholder: string;
  statusCompleted: string;
  statusInProgress: string;
  statusPlanned: string;
  deleteSemesterLabel: string;
  deleteCourseLabel: string;
}

const {
  addCourseButton,
  semesterNamePlaceholder,
  courseNamePlaceholder,
  creditsPlaceholder,
  gradePlaceholder,
  statusCompleted,
  statusInProgress,
  statusPlanned,
  deleteSemesterLabel,
  deleteCourseLabel,
} = Astro.props;
---

<template id="tracker-semester-template">
  <div class="tracker-semester-card" data-semester-id>
    <header class="tracker-semester-card-header">
      <input
        type="text"
        class="tracker-semester-title-input"
        data-semester-name-input
        placeholder={semesterNamePlaceholder}
      />
      <button type="button" class="tracker-btn-delete" data-action="delete-semester" aria-label={deleteSemesterLabel}>
        &times;
      </button>
    </header>

    <div class="tracker-courses-list" data-courses-container></div>

    <footer class="tracker-semester-card-footer">
      <button type="button" class="tracker-btn tracker-btn-ghost tracker-btn-sm" data-action="add-course">
        {addCourseButton}
      </button>
    </footer>
  </div>
</template>

<template id="tracker-course-template">
  <div class="tracker-course-row" data-course-id>
    <div class="tracker-course-row-grid">
      <input
        type="text"
        class="tracker-course-name"
        data-course-name-input
        placeholder={courseNamePlaceholder}
      />

      <input
        type="number"
        class="tracker-course-credits"
        data-course-credits-input
        placeholder={creditsPlaceholder}
        min="1"
        max="30"
      />

      <select class="tracker-course-status" data-course-status-input>
        <option value="completed">{statusCompleted}</option>
        <option value="in-progress">{statusInProgress}</option>
        <option value="planned">{statusPlanned}</option>
      </select>

      <input
        type="number"
        class="tracker-course-grade"
        data-course-grade-input
        placeholder={gradePlaceholder}
        min="0"
        max="10"
        step="0.1"
      />

      <button type="button" class="tracker-btn-delete-course" data-action="delete-course" aria-label={deleteCourseLabel}>
        &times;
      </button>
    </div>
  </div>
</template>
