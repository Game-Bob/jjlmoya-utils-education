---
interface Props {
  labels: Record<string, string>;
}

const { labels } = Astro.props;
---

<div class="prompt-generator-box">
  <h3 class="creator-title">{labels.aiPromptGenerator || 'AI Flashcard Assistant'}</h3>
  <div class="creator-form">
    <div class="form-field">
      <label for="ai-topics-input">{labels.aiTopicsLabel || 'Enter your exam topics or notes'}</label>
      <textarea
        id="ai-topics-input"
        placeholder={labels.aiTopicsPlaceholder || 'e.g., Math exam covering Derivatives, Integrals and Limits...'}
        rows="3"
        class="form-textarea"
      ></textarea>
    </div>
    <button id="generate-prompt-btn" class="primary-btn" disabled>
      {labels.generatePromptBtn || 'Generate AI Prompt'}
    </button>

    <div id="generated-prompt-container" class="form-field" style="display: none;">
      <label for="generated-prompt-output">{labels.aiPromptOutputLabel || 'Copy this prompt to ChatGPT/Gemini'}</label>
      <textarea
        id="generated-prompt-output"
        readonly
        rows="6"
        class="form-textarea readonly-textarea"
      ></textarea>
      <button id="copy-prompt-btn" class="secondary-btn">
        {labels.copyPromptBtn || 'Copy to Clipboard'}
      </button>
    </div>
  </div>
</div>
