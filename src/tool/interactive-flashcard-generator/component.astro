---
import type { InteractiveFlashcardGeneratorUI } from './index';
import FlashcardCreator from './components/FlashcardCreator.astro';
import FlashcardViewer from './components/FlashcardViewer.astro';
import FlashcardControls from './components/FlashcardControls.astro';
import CategoryManager from './components/CategoryManager.astro';
import PromptGenerator from './components/PromptGenerator.astro';

interface Props {
  ui?: Partial<InteractiveFlashcardGeneratorUI>;
}

const { ui = {} } = Astro.props;

const labels: InteractiveFlashcardGeneratorUI = {
  cardCreator: ui.cardCreator || 'Flashcard Creator',
  questionLabel: ui.questionLabel || 'Front (Question)',
  answerLabel: ui.answerLabel || 'Back (Answer)',
  addCard: ui.addCard || 'Add Flashcard',
  questionPlaceholder: ui.questionPlaceholder || 'e.g., What is the capital of France?',
  answerPlaceholder: ui.answerPlaceholder || 'e.g., Paris',
  reviewMode: ui.reviewMode || 'Study Session',
  cardIndex: ui.cardIndex || 'Card',
  flipCard: ui.flipCard || 'Click to flip',
  nextCard: ui.nextCard || 'Next',
  prevCard: ui.prevCard || 'Previous',
  easy: ui.easy || 'Easy',
  medium: ui.medium || 'Medium',
  hard: ui.hard || 'Hard',
  resetSession: ui.resetSession || 'Reset Progress',
  importExport: ui.importExport || 'Deck Management',
  importDeck: ui.importDeck || 'Import JSON',
  exportDeck: ui.exportDeck || 'Export JSON',
  emptyDeckWarning: ui.emptyDeckWarning || 'Your deck is empty. Create a card or import a deck to start studying.',
  sampleQuestion1: ui.sampleQuestion1 || 'What is active recall?',
  sampleAnswer1: ui.sampleAnswer1 || 'A learning technique that involves actively stimulating memory retrieval during the learning process.',
  sampleQuestion2: ui.sampleQuestion2 || 'Who formulated the forgetting curve hypothesis?',
  sampleAnswer2: ui.sampleAnswer2 || 'Hermann Ebbinghaus, who studied the exponential nature of forgetting information over time.',
  selectAll: ui.selectAll || 'Select All',
  deleteCategory: ui.deleteCategory || 'Delete Category',
  deleteConfirmMsg: ui.deleteConfirmMsg || 'Are you sure you want to delete this category and all its cards?',
  cancel: ui.cancel || 'Cancel',
  delete: ui.delete || 'Delete',
  pasteJsonTitle: ui.pasteJsonTitle || 'Paste Flashcard JSON',
  pasteJsonPlaceholder: ui.pasteJsonPlaceholder || 'Paste the JSON generated by AI here...',
  importBtn: ui.importBtn || 'Import',
  aiPromptTemplate: ui.aiPromptTemplate || 'Act as an educational assistant. Generate a set of flashcards for the following topics:\n"{topics}"\n\nOutput the result ONLY as a raw JSON object matching the exact structure below. Do not include markdown code block formatting (like ```json), do not include any explanatory text, and do not wrap the output in any other way. Output only valid raw JSON:\n{\n  "categories": ["Math Exam"],\n  "deck": [\n    {\n      "question": "[Flashcard Front / Question]",\n      "answer": "[Flashcard Back / Answer]",\n      "category": "Math Exam",\n      "score": null\n    }\n  ]\n}',
};
---

<div class="interactive-flashcard-container view-fade-in">
  <div class="flashcard-layout">
    <div class="creator-column">
      <PromptGenerator labels={labels} />
      <CategoryManager labels={labels} />
      <FlashcardCreator labels={labels} />
    </div>

    <div class="viewer-column">
      <FlashcardViewer labels={labels} />
      <FlashcardControls labels={labels} />
    </div>
  </div>
</div>

<div id="import-text-modal" class="modal-backdrop" style="display: none;">
  <div class="modal-content">
    <h4 class="modal-title">{labels.pasteJsonTitle}</h4>
    <textarea id="import-text-textarea" placeholder={labels.pasteJsonPlaceholder} rows="8" class="form-textarea"></textarea>
    <div class="modal-actions">
      <button id="import-text-cancel" class="secondary-btn">{labels.cancel}</button>
      <button id="import-text-confirm" class="primary-btn">{labels.importBtn}</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ labels }}>
  const DECK_STORAGE_KEY = 'jjlmoya_flashcards_deck_v2';
  const CAT_STORAGE_KEY = 'jjlmoya_flashcards_cats_v2';

  let deck = [];
  let categories = [];
  let selectedCategories = [];
  let filteredDeck = [];
  let currentIndex = 0;

  const activeCardEl = document.getElementById('active-flashcard');
  const cardFrontContent = document.getElementById('card-front-content');
  const cardBackContent = document.getElementById('card-back-content');
  const cardProgressIndicator = document.getElementById('card-progress-indicator');
  const deckProgressFill = document.getElementById('deck-progress-fill');

  const questionInput = document.getElementById('card-question-input');
  const answerInput = document.getElementById('card-answer-input');
  const addCardBtn = document.getElementById('add-card-btn');
  const cardCategorySelect = document.getElementById('card-category-select');

  const prevCardBtn = document.getElementById('prev-card-btn');
  const nextCardBtn = document.getElementById('next-card-btn');

  const scoreEasyBtn = document.getElementById('score-easy-btn');
  const scoreMediumBtn = document.getElementById('score-medium-btn');
  const scoreHardBtn = document.getElementById('score-hard-btn');
  const resetDeckBtn = document.getElementById('reset-deck-btn');

  const exportAllBtn = document.getElementById('export-all-btn');
  const importDeckFile = document.getElementById('import-deck-file');

  const deleteConfirmModal = document.getElementById('delete-confirm-modal');
  const deleteModalMessage = document.getElementById('delete-modal-message');
  const deleteModalCancel = document.getElementById('delete-modal-cancel');
  const deleteModalConfirm = document.getElementById('delete-modal-confirm');

  let categoryToDelete = '';

  const newCategoryInput = document.getElementById('new-category-input');
  const addCategoryBtn = document.getElementById('add-category-btn');
  const categoriesCheckboxesList = document.getElementById('categories-checkboxes-list');
  const selectAllCategories = document.getElementById('select-all-categories');

  const aiTopicsInput = document.getElementById('ai-topics-input');
  const generatePromptBtn = document.getElementById('generate-prompt-btn');
  const generatedPromptContainer = document.getElementById('generated-prompt-container');
  const generatedPromptOutput = document.getElementById('generated-prompt-output');
  const copyPromptBtn = document.getElementById('copy-prompt-btn');

  const importTextBtn = document.getElementById('import-text-btn');
  const importTextModal = document.getElementById('import-text-modal');
  const importTextTextarea = document.getElementById('import-text-textarea');
  const importTextCancel = document.getElementById('import-text-cancel');
  const importTextConfirm = document.getElementById('import-text-confirm');

  const elements = {
    activeCardEl, cardFrontContent, cardBackContent, cardProgressIndicator, deckProgressFill,
    questionInput, answerInput, addCardBtn, cardCategorySelect, prevCardBtn, nextCardBtn,
    scoreEasyBtn, scoreMediumBtn, scoreHardBtn, resetDeckBtn, exportAllBtn, importDeckFile,
    deleteConfirmModal, deleteModalMessage, deleteModalCancel, deleteModalConfirm,
    newCategoryInput, addCategoryBtn, categoriesCheckboxesList, selectAllCategories,
    aiTopicsInput, generatePromptBtn, generatedPromptContainer, generatedPromptOutput, copyPromptBtn,
    importTextBtn, importTextModal, importTextTextarea, importTextCancel, importTextConfirm
  };
  Object.entries(elements).forEach(([name, el]) => {
    if (!el) console.error('ELEMENT NULL:', name);
  });

  function init() {
    try {
      const storedDeck = localStorage.getItem(DECK_STORAGE_KEY);
      const storedCats = localStorage.getItem(CAT_STORAGE_KEY);

      if (storedCats) {
        categories = JSON.parse(storedCats);
      } else {
        categories = ['General', 'Exam 1', 'Exam 2'];
        saveCategories();
      }

      if (storedDeck) {
        deck = JSON.parse(storedDeck);
      } else {
        deck = [
          { question: labels.sampleQuestion1, answer: labels.sampleAnswer1, category: 'General', score: null },
          { question: labels.sampleQuestion2, answer: labels.sampleAnswer2, category: 'General', score: null }
        ];
        saveDeck();
      }
    } catch (e) {
      categories = ['General'];
      deck = [
        { question: labels.sampleQuestion1, answer: labels.sampleAnswer1, category: 'General', score: null }
      ];
    }

    selectedCategories = [...categories];
    updateCategoryUI();
    updateFilteredDeck();
    render();
  }

  function saveDeck() {
    localStorage.setItem(DECK_STORAGE_KEY, JSON.stringify(deck));
  }

  function saveCategories() {
    localStorage.setItem(CAT_STORAGE_KEY, JSON.stringify(categories));
  }

  function updateCategoryUI() {
    cardCategorySelect.innerHTML = '';
    categories.forEach(cat => {
      const option = document.createElement('option');
      option.value = cat;
      option.textContent = cat;
      cardCategorySelect.appendChild(option);
    });

    categoriesCheckboxesList.innerHTML = '';
    categories.forEach(cat => {
      const row = document.createElement('div');
      row.className = 'category-item-row';

      const label = document.createElement('label');
      label.className = 'checkbox-label';
      
      const checkbox = document.createElement('input');
      checkbox.type = 'checkbox';
      checkbox.value = cat;
      checkbox.checked = selectedCategories.includes(cat);
      checkbox.addEventListener('change', () => {
        if (checkbox.checked) {
          if (!selectedCategories.includes(cat)) {
            selectedCategories.push(cat);
          }
        } else {
          selectedCategories = selectedCategories.filter(c => c !== cat);
        }
        updateSelectAllState();
        updateFilteredDeck();
        render();
      });

      const span = document.createElement('span');
      span.textContent = cat;

      label.appendChild(checkbox);
      label.appendChild(span);
      row.appendChild(label);

      const actions = document.createElement('div');
      actions.className = 'category-item-actions';

      const exportBtn = document.createElement('button');
      exportBtn.className = 'icon-btn';
      exportBtn.title = 'Export Category';
      exportBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M17 8l-5-5-5 5M12 3v12"></path></svg>`;
      exportBtn.addEventListener('click', (e) => {
        e.preventDefault();
        const exportData = {
          categories: [cat],
          deck: deck.filter(c => c.category === cat)
        };
        const dataStr = 'data:text/json;charset=utf-8,' + encodeURIComponent(JSON.stringify(exportData));
        const downloadAnchor = document.createElement('a');
        downloadAnchor.setAttribute('href', dataStr);
        downloadAnchor.setAttribute('download', `flashcards-${cat.toLowerCase().replace(/\s+/g, '-')}.json`);
        document.body.appendChild(downloadAnchor);
        downloadAnchor.click();
        downloadAnchor.remove();
      });

      const deleteBtn = document.createElement('button');
      deleteBtn.className = 'icon-btn delete-btn-color';
      deleteBtn.title = 'Delete Category';
      deleteBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>`;
      deleteBtn.addEventListener('click', (e) => {
        e.preventDefault();
        categoryToDelete = cat;
        deleteModalMessage.textContent = `${labels.deleteConfirmMsg.replace('this category', `"${cat}"`)}`;
        deleteConfirmModal.style.display = 'flex';
      });

      actions.appendChild(exportBtn);
      if (categories.length > 1) {
        actions.appendChild(deleteBtn);
      }
      row.appendChild(actions);

      categoriesCheckboxesList.appendChild(row);
    });
    updateSelectAllState();
  }

  function updateSelectAllState() {
    selectAllCategories.checked = selectedCategories.length === categories.length;
  }

  selectAllCategories.addEventListener('change', () => {
    if (selectAllCategories.checked) {
      selectedCategories = [...categories];
    } else {
      selectedCategories = [];
    }
    updateCategoryUI();
    updateFilteredDeck();
    render();
  });

  addCategoryBtn.addEventListener('click', () => {
    const catName = newCategoryInput.value.trim();
    if (!catName || categories.includes(catName)) return;

    categories.push(catName);
    selectedCategories.push(catName);
    saveCategories();
    newCategoryInput.value = '';
    updateCategoryUI();
    updateFilteredDeck();
    render();
  });

  function updateFilteredDeck() {
    filteredDeck = deck.filter(card => selectedCategories.includes(card.category));
    if (currentIndex >= filteredDeck.length) {
      currentIndex = 0;
    }
  }

  function restartAnimation(className) {
    activeCardEl.classList.remove(className);
    void activeCardEl.offsetWidth;
    activeCardEl.classList.add(className);
  }

  function animateCardFlip() {
    restartAnimation('card-pulse');
  }

  function animateCardTravel(direction) {
    restartAnimation(direction === 'prev' ? 'slide-prev' : 'slide-next');
  }

  function render() {
    if (activeCardEl.classList.contains('flipped')) {
      activeCardEl.classList.remove('flipped');
    }

    if (filteredDeck.length === 0) {
      cardFrontContent.textContent = labels.emptyDeckWarning;
      cardBackContent.textContent = labels.emptyDeckWarning;
      cardProgressIndicator.textContent = '0 / 0';
      deckProgressFill.style.width = '0%';
      return;
    }

    const currentCard = filteredDeck[currentIndex];
    cardFrontContent.textContent = currentCard.question;
    cardBackContent.textContent = currentCard.answer;

    cardProgressIndicator.textContent = `${currentIndex + 1} / ${filteredDeck.length}`;

    const scoredCount = filteredDeck.filter(c => c.score !== null && c.score !== undefined).length;
    const percentage = filteredDeck.length > 0 ? (scoredCount / filteredDeck.length) * 100 : 0;
    deckProgressFill.style.width = `${percentage}%`;
  }

  activeCardEl.addEventListener('click', () => {
    activeCardEl.classList.toggle('flipped');
    animateCardFlip();
  });

  addCardBtn.addEventListener('click', () => {
    const q = questionInput.value.trim();
    const a = answerInput.value.trim();
    const cat = cardCategorySelect.value;
    if (!q || !a || !cat) return;

    deck.push({ question: q, answer: a, category: cat, score: null });
    saveDeck();

    questionInput.value = '';
    answerInput.value = '';

    updateFilteredDeck();
    if (selectedCategories.includes(cat)) {
      currentIndex = filteredDeck.findIndex(c => c.question === q && c.answer === a);
    }
    render();
    animateCardFlip();
  });

  prevCardBtn.addEventListener('click', () => {
    if (filteredDeck.length === 0) return;
    currentIndex = (currentIndex - 1 + filteredDeck.length) % filteredDeck.length;
    animateCardTravel('prev');
    render();
  });

  nextCardBtn.addEventListener('click', () => {
    if (filteredDeck.length === 0) return;
    currentIndex = (currentIndex + 1) % filteredDeck.length;
    animateCardTravel('next');
    render();
  });

  function rateCard(difficulty) {
    if (filteredDeck.length === 0) return;
    const currentCard = filteredDeck[currentIndex];
    const originalIndex = deck.findIndex(c => c.question === currentCard.question && c.answer === currentCard.answer && c.category === currentCard.category);
    if (originalIndex !== -1) {
      deck[originalIndex].score = difficulty;
      saveDeck();
    }
    updateFilteredDeck();
    currentIndex = (currentIndex + 1) % filteredDeck.length;
    render();
    animateCardFlip();
  }

  scoreEasyBtn.addEventListener('click', () => rateCard('easy'));
  scoreMediumBtn.addEventListener('click', () => rateCard('medium'));
  scoreHardBtn.addEventListener('click', () => rateCard('hard'));

  resetDeckBtn.addEventListener('click', () => {
    filteredDeck.forEach(c => {
      const originalIndex = deck.findIndex(orig => orig.question === c.question && orig.answer === c.answer && orig.category === c.category);
      if (originalIndex !== -1) {
        deck[originalIndex].score = null;
      }
    });
    saveDeck();
    currentIndex = 0;
    updateFilteredDeck();
    render();
  });

  exportAllBtn.addEventListener('click', () => {
    const exportData = {
      categories,
      deck
    };
    const dataStr = 'data:text/json;charset=utf-8,' + encodeURIComponent(JSON.stringify(exportData));
    const downloadAnchor = document.createElement('a');
    downloadAnchor.setAttribute('href', dataStr);
    downloadAnchor.setAttribute('download', 'flashcards-all.json');
    document.body.appendChild(downloadAnchor);
    downloadAnchor.click();
    downloadAnchor.remove();
  });

  deleteModalCancel.addEventListener('click', () => {
    deleteConfirmModal.style.display = 'none';
    categoryToDelete = '';
  });

  deleteModalConfirm.addEventListener('click', () => {
    if (!categoryToDelete) return;
    categories = categories.filter(c => c !== categoryToDelete);
    selectedCategories = selectedCategories.filter(c => c !== categoryToDelete);
    deck = deck.filter(c => c.category !== categoryToDelete);
    saveCategories();
    saveDeck();
    deleteConfirmModal.style.display = 'none';
    categoryToDelete = '';
    updateCategoryUI();
    updateFilteredDeck();
    render();
  });

  importDeckFile.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const parsed = JSON.parse(event.target.result);
        if (parsed && Array.isArray(parsed.categories) && Array.isArray(parsed.deck)) {
          parsed.categories.forEach(cat => {
            if (!categories.includes(cat)) {
              categories.push(cat);
            }
            if (!selectedCategories.includes(cat)) {
              selectedCategories.push(cat);
            }
          });
          parsed.deck.forEach(importedCard => {
            const exists = deck.some(orig => 
              orig.question === importedCard.question && 
              orig.answer === importedCard.answer && 
              orig.category === (importedCard.category || 'General')
            );
            if (!exists) {
              deck.push({
                question: importedCard.question || '',
                answer: importedCard.answer || '',
                category: importedCard.category || 'General',
                score: importedCard.score || null
              });
            }
          });
          saveCategories();
          saveDeck();
          updateCategoryUI();
          updateFilteredDeck();
          render();
        }
      } catch (err) {}
    };
    reader.readAsText(file);
  });

  window.addEventListener('keydown', (e) => {
    if (document.activeElement.tagName === 'TEXTAREA' || document.activeElement.tagName === 'INPUT' || document.activeElement.tagName === 'SELECT') {
      return;
    }
    if (filteredDeck.length === 0) return;

    if (e.key === ' ' || e.key === 'ArrowUp' || e.key === 'ArrowDown') {
      e.preventDefault();
      activeCardEl.classList.toggle('flipped');
      animateCardFlip();
    } else if (e.key === 'ArrowLeft') {
      currentIndex = (currentIndex - 1 + filteredDeck.length) % filteredDeck.length;
      animateCardTravel('prev');
      render();
    } else if (e.key === 'ArrowRight') {
      currentIndex = (currentIndex + 1) % filteredDeck.length;
      animateCardTravel('next');
      render();
    } else if (e.key === '1') {
      rateCard('easy');
    } else if (e.key === '2') {
      rateCard('medium');
    } else if (e.key === '3') {
      rateCard('hard');
    }
  });

  aiTopicsInput.addEventListener('input', () => {
    generatePromptBtn.disabled = !aiTopicsInput.value.trim();
  });

  generatePromptBtn.addEventListener('click', () => {
    const topics = aiTopicsInput.value.trim();
    if (!topics) return;

    const basePrompt = labels.aiPromptTemplate.replace('{topics}', topics);

    generatedPromptOutput.value = basePrompt;
    generatedPromptContainer.style.display = 'flex';
  });

  copyPromptBtn.addEventListener('click', () => {
    generatedPromptOutput.select();
    navigator.clipboard.writeText(generatedPromptOutput.value).then(() => {
      const origText = copyPromptBtn.textContent;
      copyPromptBtn.textContent = 'Copied!';
      copyPromptBtn.classList.add('copied');
      setTimeout(() => {
        copyPromptBtn.textContent = origText;
        copyPromptBtn.classList.remove('copied');
      }, 2000);
    });
  });

  importTextBtn.addEventListener('click', () => {
    importTextTextarea.value = '';
    importTextModal.style.display = 'flex';
  });

  importTextCancel.addEventListener('click', () => {
    importTextModal.style.display = 'none';
  });

  importTextConfirm.addEventListener('click', () => {
    let rawVal = importTextTextarea.value.trim();
    if (!rawVal) return;

    if (rawVal.startsWith('```')) {
      rawVal = rawVal.replace(/^```[a-zA-Z]*\s*/, '');
      rawVal = rawVal.replace(/\s*```$/, '');
      rawVal = rawVal.trim();
    }

    try {
      const parsed = JSON.parse(rawVal);
      if (parsed && Array.isArray(parsed.categories) && Array.isArray(parsed.deck)) {
        parsed.categories.forEach(cat => {
          if (!categories.includes(cat)) {
            categories.push(cat);
          }
          if (!selectedCategories.includes(cat)) {
            selectedCategories.push(cat);
          }
        });
        parsed.deck.forEach(importedCard => {
          const exists = deck.some(orig => 
            orig.question === importedCard.question && 
            orig.answer === importedCard.answer && 
            orig.category === (importedCard.category || 'General')
          );
          if (!exists) {
            deck.push({
              question: importedCard.question || '',
              answer: importedCard.answer || '',
              category: importedCard.category || 'General',
              score: importedCard.score || null
            });
          }
        });
        saveCategories();
        saveDeck();
        updateCategoryUI();
        updateFilteredDeck();
        render();
        importTextModal.style.display = 'none';
      }
    } catch (err) {}
  });

  init();
</script>
