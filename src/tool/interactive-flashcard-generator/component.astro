---
import type { InteractiveFlashcardGeneratorUI } from './index';
import FlashcardCreator from './components/FlashcardCreator.astro';
import FlashcardViewer from './components/FlashcardViewer.astro';
import FlashcardControls from './components/FlashcardControls.astro';
import CategoryManager from './components/CategoryManager.astro';
import PromptGenerator from './components/PromptGenerator.astro';

interface Props {
  ui?: Partial<InteractiveFlashcardGeneratorUI>;
}

const { ui = {} } = Astro.props;

const labels: InteractiveFlashcardGeneratorUI = {
  cardCreator: ui.cardCreator || 'Flashcard Creator',
  questionLabel: ui.questionLabel || 'Front (Question)',
  answerLabel: ui.answerLabel || 'Back (Answer)',
  addCard: ui.addCard || 'Add Flashcard',
  questionPlaceholder: ui.questionPlaceholder || 'e.g., What is the capital of France?',
  answerPlaceholder: ui.answerPlaceholder || 'e.g., Paris',
  reviewMode: ui.reviewMode || 'Study Session',
  cardIndex: ui.cardIndex || 'Card',
  flipCard: ui.flipCard || 'Click to flip',
  nextCard: ui.nextCard || 'Next',
  prevCard: ui.prevCard || 'Previous',
  easy: ui.easy || 'Easy',
  medium: ui.medium || 'Medium',
  hard: ui.hard || 'Hard',
  resetSession: ui.resetSession || 'Reset Progress',
  importExport: ui.importExport || 'Deck Management',
  importDeck: ui.importDeck || 'Import JSON',
  exportDeck: ui.exportDeck || 'Export JSON',
  exportSelected: ui.exportSelected || 'Export Selected',
  exportAll: ui.exportAll || 'Export All Decks',
  emptyDeckWarning: ui.emptyDeckWarning || 'Your deck is empty. Create a card or import a deck to start studying.',
  sampleQuestion1: ui.sampleQuestion1 || 'What is active recall?',
  sampleAnswer1: ui.sampleAnswer1 || 'A learning technique that involves actively stimulating memory retrieval during the learning process.',
  sampleQuestion2: ui.sampleQuestion2 || 'Who formulated the forgetting curve hypothesis?',
  sampleAnswer2: ui.sampleAnswer2 || 'Hermann Ebbinghaus, who studied the exponential nature of forgetting information over time.',
  aiPromptGenerator: ui.aiPromptGenerator || 'AI Flashcard Assistant',
  aiTopicsLabel: ui.aiTopicsLabel || 'Enter your exam topics or notes',
  aiTopicsPlaceholder: ui.aiTopicsPlaceholder || 'e.g., Math exam covering Derivatives, Integrals and Limits...',
  generatePromptBtn: ui.generatePromptBtn || 'Generate AI Prompt',
  aiPromptOutputLabel: ui.aiPromptOutputLabel || 'Copy this prompt to ChatGPT/Gemini',
  copyPromptBtn: ui.copyPromptBtn || 'Copy to Clipboard',
  selectAll: ui.selectAll || 'Select All',
  deleteCategory: ui.deleteCategory || 'Delete Category',
  deleteConfirmMsg: ui.deleteConfirmMsg || 'Are you sure you want to delete this category and all its cards?',
  cancel: ui.cancel || 'Cancel',
  delete: ui.delete || 'Delete',
  pasteJsonTitle: ui.pasteJsonTitle || 'Paste Flashcard JSON',
  pasteJsonPlaceholder: ui.pasteJsonPlaceholder || 'Paste the JSON generated by AI here...',
  importBtn: ui.importBtn || 'Import',
  aiPromptTemplate: ui.aiPromptTemplate || '',
};
---

<div class="interactive-flashcard-container view-fade-in" data-flashcard-labels={JSON.stringify(labels)}>
  <div class="flashcard-layout">
    <div class="creator-column">
      <PromptGenerator labels={labels} />
      <CategoryManager labels={labels} />
      <FlashcardCreator labels={labels} />
    </div>

    <div class="viewer-column">
      <FlashcardViewer labels={labels} />
      <FlashcardControls labels={labels} />
    </div>
  </div>
</div>

<div id="import-text-modal" class="modal-backdrop" style="display: none;">
  <div class="modal-content">
    <h4 class="modal-title">{labels.pasteJsonTitle}</h4>
    <textarea id="import-text-textarea" placeholder={labels.pasteJsonPlaceholder} rows="8" class="form-textarea"></textarea>
    <div class="modal-actions">
      <button id="import-text-cancel" class="secondary-btn">{labels.cancel}</button>
      <button id="import-text-confirm" class="primary-btn">{labels.importBtn}</button>
    </div>
  </div>
</div>

<script>
  import { initInteractiveFlashcardGenerator } from './script';

  const container = document.querySelector<HTMLElement>('.interactive-flashcard-container');
  const rawLabels = container?.dataset.flashcardLabels ?? '{}';

  initInteractiveFlashcardGenerator(JSON.parse(rawLabels));
</script>
