---
import SEORenderer from '@jjlmoya/utils-shared/seo/SEORenderer.astro';
import { citationGenerator } from './index';
import type { KnownLocale } from '../../types';

interface Props {
  locale?: KnownLocale;
}

const { locale = 'es' } = Astro.props as Props;
const i18nContent = await citationGenerator.i18n[locale]?.();
if (!i18nContent) return null;
---

<SEORenderer content={{ sections: i18nContent.seo }} />
