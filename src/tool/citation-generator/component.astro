---
import { Icon } from 'astro-icon/components';
import type { CitationGeneratorUI } from "./index";

interface Props {
  ui?: Partial<CitationGeneratorUI>;
}

const { ui = {} } = Astro.props;
const labels = {
  format: ui.format || "Format",
  book: ui.book || "Book",
  website: ui.website || "Website",
  article: ui.article || "Article",
  publicationYear: ui.publicationYear || "Publication Year",
  authors: ui.authors || "Authors (Last Name, Initials)",
  title: ui.title || "Title",
  publisher: ui.publisher || "Publisher",
  locationUrl: ui.locationUrl || "Location / URL",
  preview: ui.preview || "Preview",
  saveToList: ui.saveToList || "Save to my list",
  mySavedCitations: ui.mySavedCitations || "My Saved Citations",
  noSavedCitations: ui.noSavedCitations || "You have no saved citations.",
  clickToCopy: ui.clickToCopy || "Click on the citation to copy it directly",
  apa: ui.apa || "APA (7th ed.)",
  mla: ui.mla || "MLA (9th ed.)",
  vancouver: ui.vancouver || "Vancouver",
  exampleAuthor: ui.exampleAuthor || "Perez, J.; Garcia, M.",
  exampleYear: ui.exampleYear || "2024",
};
---

<div class="citation-generator-ui citation-generator-container view-fade-in">
    <div class="type-tabs">
        <button class="type-tab active" data-type="book">{labels.book}</button>
        <button class="type-tab" data-type="website">{labels.website}</button>
        <button class="type-tab" data-type="article">{labels.article}</button>
    </div>

    <div class="generator-grid">
        <div class="config-section">
            <div class="form-grid">
                <div class="field-group">
                    <label class="field-label">{labels.format}</label>
                    <select id="citation-style" class="input-control select-control">
                        <option value="apa">{labels.apa}</option>
                        <option value="mla">{labels.mla}</option>
                        <option value="vancouver">{labels.vancouver}</option>
                    </select>
                </div>
                <div class="field-group">
                    <label class="field-label">{labels.publicationYear}</label>
                    <input
                        type="text"
                        id="year"
                        class="input-control"
                        placeholder={`Ex: ${labels.exampleYear}`}
                    />
                </div>
            </div>

            <div class="field-group">
                <label class="field-label">{labels.authors}</label>
                <input
                    type="text"
                    id="authors"
                    class="input-control"
                    placeholder={`Ex: ${labels.exampleAuthor}`}
                />
            </div>

            <div class="field-group">
                <label class="field-label" id="title-label">{labels.title}</label>
                <input
                    type="text"
                    id="title"
                    class="input-control"
                    placeholder="Enter the complete title"
                />
            </div>

            <div class="form-grid">
                <div class="field-group" id="extra-field-container">
                    <label class="field-label" id="extra-label">{labels.publisher}</label>
                    <input
                        type="text"
                        id="extra-field"
                        class="input-control"
                        placeholder="Ex: Publishing House"
                    />
                </div>
                <div class="field-group">
                    <label class="field-label">{labels.locationUrl}</label>
                    <input
                        type="text"
                        id="location-url"
                        class="input-control"
                        placeholder="Ex: City or https://..."
                    />
                </div>
            </div>

            <button id="add-to-history" class="add-btn">
                <Icon name="mdi:plus" width="20" height="20" />
                {labels.saveToList}
            </button>
        </div>

        <div class="results-sidebar">
            <div class="preview-card">
                <div class="preview-title">{labels.preview}</div>
                <div id="citation-output" class="citation-result" title="Click to copy">
                    Enter data to generate the citation...
                </div>
                <div class="copy-actions">
                    <button class="copy-btn" id="copy-formatted" title="Copy with formatting">
                        <Icon name="mdi:content-copy" width="16" height="16" />
                    </button>
                    <button class="copy-btn" id="copy-text" title="Copy plain text">
                        <Icon name="mdi:text" width="16" height="16" />
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="history-section">
        <h3 class="history-title">{labels.mySavedCitations}</h3>
        <div id="history-list" class="history-list"></div>
    </div>
</div>

<script is:inline define:vars={{ labels }}>
    const STORAGE_KEY = "jjlmoya_citations_v1";

    const inputs = {
        style: document.getElementById("citation-style"),
        year: document.getElementById("year"),
        authors: document.getElementById("authors"),
        title: document.getElementById("title"),
        extra: document.getElementById("extra-field"),
        location: document.getElementById("location-url"),
    };

    const output = document.getElementById("citation-output");
    const historyList = document.getElementById("history-list");
    const addBtn = document.getElementById("add-to-history");
    const tabs = document.querySelectorAll(".type-tab");

    const labelEls = {
        title: document.getElementById("title-label"),
        extra: document.getElementById("extra-label"),
    };

    let currentType = "book";

    function formatAPA(data) {
        const { authors, year, title, extra, location, type } = data;
        const authorStr = authors ? `${authors}. ` : "";
        const yearStr = year ? `(${year}). ` : "";

        if (type === "book") {
            return `${authorStr}${yearStr}<em>${title}</em>. ${extra}.`;
        } else if (type === "website") {
            return `${authorStr}${yearStr}<em>${title}</em>. ${extra}. Retrieved from ${location}`;
        } else {
            return `${authorStr}${yearStr}${title}. <em>${extra}</em>. ${location}`;
        }
    }

    function formatMLA(data) {
        const { authors, year, title, extra, location, type } = data;
        const authorStr = authors ? `${authors}. ` : "";

        if (type === "book") {
            return `${authorStr}<em>${title}</em>. ${extra}, ${year}.`;
        } else if (type === "website") {
            return `${authorStr}"${title}." <em>${extra}</em>, ${year}, ${location}.`;
        } else {
            return `${authorStr}"${title}." <em>${extra}</em>, vol. ${location}, ${year}.`;
        }
    }

    function formatVancouver(data) {
        const { authors, year, title, extra, location, type } = data;
        const authorStr = authors ? `${authors}. ` : "";

        if (type === "book") {
            return `${authorStr}${title}. ${location}: ${extra}; ${year}.`;
        } else if (type === "website") {
            return `${authorStr}${title} [Internet]. ${extra}; ${year} [cited ${new Date().toLocaleDateString()}]. Available from: ${location}`;
        } else {
            return `${authorStr}${title}. ${extra}. ${year};${location}.`;
        }
    }

    function updatePreview() {
        const data = {
            id: "",
            authors: inputs.authors.value.trim(),
            year: inputs.year.value.trim(),
            title: inputs.title.value.trim(),
            extra: inputs.extra.value.trim(),
            location: inputs.location.value.trim(),
            type: currentType,
            style: inputs.style.value,
            formatted: "",
        };

        if (!data.title) {
            if (output) output.innerHTML = "Enter at least the title...";
            return;
        }

        const style = inputs.style.value;
        let formatted = "";

        if (style === "apa") formatted = formatAPA(data);
        else if (style === "mla") formatted = formatMLA(data);
        else formatted = formatVancouver(data);

        if (output) output.innerHTML = formatted;
        return formatted;
    }

    function saveToLocalStorage(item) {
        const saved = localStorage.getItem(STORAGE_KEY);
        const list = saved ? JSON.parse(saved) : [];
        list.unshift(item);
        localStorage.setItem(STORAGE_KEY, JSON.stringify(list));
        renderHistory();
    }

    function createHistoryItem(item, list) {
        const el = document.createElement("div");
        el.className = "history-item";
        el.innerHTML = `
            <div class="history-text">${item.formatted}</div>
            <div class="history-actions">
                <button class="action-btn btn-copy-formatted" title="Copy with formatting"><svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z"/></svg></button>
                <button class="action-btn btn-copy-text" title="Copy plain text"><svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18"><path d="M4 6h16V4H4c-1.1 0-2 .9-2 2v12H0v4h14v-4H4V6zm16-2v6h6V4h-6z"/></svg></button>
                <button class="action-btn btn-delete" title="Delete"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-9l-1 1H5v2h14V4z"/></svg></button>
            </div>
        `;

        el.querySelector(".btn-delete")?.addEventListener("click", () => {
            const newList = list.filter((i) => i.id !== item.id);
            localStorage.setItem(STORAGE_KEY, JSON.stringify(newList));
            renderHistory();
        });

        el.querySelector(".btn-copy-formatted")?.addEventListener("click", (e) => {
            e.stopPropagation();
            navigator.clipboard.writeText(item.formatted);
            showCopyFeedback(el.querySelector(".btn-copy-formatted"));
        });

        el.querySelector(".btn-copy-text")?.addEventListener("click", (e) => {
            e.stopPropagation();
            const textEl = el.querySelector(".history-text");
            const text = textEl?.textContent || "";
            navigator.clipboard.writeText(text);
            showCopyFeedback(el.querySelector(".btn-copy-text"));
        });

        return el;
    }

    function renderHistory() {
        if (!historyList) return;
        const saved = localStorage.getItem(STORAGE_KEY);
        const list = saved ? JSON.parse(saved) : [];

        historyList.innerHTML = list.length ? "" : 
            `<div style="text-align: center; opacity: 0.5; padding: 2rem;">${labels.noSavedCitations}</div>`;

        list.forEach((item) => {
            historyList.appendChild(createHistoryItem(item, list));
        });
    }

    const typeConfig = {
        book: { label: labels.publisher, placeholder: "Ex: Publishing House" },
        website: { label: "Website Name", placeholder: "Ex: Wikipedia or CNN" },
        article: { label: "Journal Name", placeholder: "Ex: Nature or Journal of Medicine" }
    };

    tabs.forEach((tab) => {
        tab.addEventListener("click", () => {
            tabs.forEach((t) => t.classList.remove("active"));
            tab.classList.add("active");
            currentType = tab.getAttribute("data-type") || "book";
            
            const config = typeConfig[currentType];
            if (labelEls.extra) labelEls.extra.textContent = config.label;
            inputs.extra.placeholder = config.placeholder;
            updatePreview();
        });
    });

    Object.values(inputs).forEach((input) => {
        input.addEventListener("input", updatePreview);
    });

    addBtn?.addEventListener("click", () => {
        const formatted = updatePreview();
        if (formatted && formatted !== "Enter at least the title...") {
            saveToLocalStorage({
                id: Date.now().toString(),
                authors: inputs.authors.value,
                year: inputs.year.value,
                title: inputs.title.value,
                extra: inputs.extra.value,
                location: inputs.location.value,
                style: inputs.style.value,
                type: currentType,
                formatted: formatted,
            });
        }
    });

    function showCopyFeedback(btn) {
        const originalHtml = btn.innerHTML;
        btn.classList.add("copied");
        btn.innerHTML = '<svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20"><path d="M9 16.2L4.8 12l-1.4 1.4L9 19 21 7l-1.4-1.4L9 16.2z"/></svg>';
        setTimeout(() => {
            btn.classList.remove("copied");
            btn.innerHTML = originalHtml;
        }, 1500);
    }

    document.getElementById("copy-formatted")?.addEventListener("click", () => {
        const html = output?.innerHTML || "";
        if (html && html !== "Enter data to generate the citation...") {
            navigator.clipboard.writeText(html);
            showCopyFeedback(document.getElementById("copy-formatted"));
        }
    });

    document.getElementById("copy-text")?.addEventListener("click", () => {
        const text = output?.textContent || "";
        if (text && text !== "Enter data to generate the citation...") {
            navigator.clipboard.writeText(text);
            showCopyFeedback(document.getElementById("copy-text"));
        }
    });

    renderHistory();
</script>

