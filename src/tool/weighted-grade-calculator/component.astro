---
import type { WeightedGradeCalculatorUI } from "./index";

interface Props {
    ui?: Partial<WeightedGradeCalculatorUI>;
}

const { ui = {} } = Astro.props;
const labels = {
    subjects: ui.subjects || "Asignaturas y Ponderaciones",
    addSubject: ui.addSubject || "Añadir Asignatura",
    subjectName: ui.subjectName || "Asignatura",
    grade: ui.grade || "Nota",
    weight: ui.weight || "Peso (%)",
    scale: ui.scale || "Escala total (Ej: 10, 20, 100)",
    finalGrade: ui.finalGrade || "Nota Final Ponderada",
    removeSubject: ui.removeSubject || "Eliminar asignatura",
    weightSum: ui.weightSum || "Suma de pesos",
    exampleSubject: ui.exampleSubject || "Matemáticas II",
    newSubjectPlaceholder: ui.newSubjectPlaceholder || "Nueva Asignatura",
};
---

<div class="weighted-calc-ui weighted-calc-container view-fade-in">
    <div class="calc-header">
        <h2 class="calc-title">{labels.subjects}</h2>
        <div class="header-actions">
            <div class="scale-setting">
                <label class="input-label" for="grade-scale"
                    >{labels.scale}</label
                >
                <input
                    type="number"
                    id="grade-scale"
                    class="input-control scale-input"
                    value="10"
                    min="1"
                    step="any"
                />
            </div>
            <button id="add-subject" class="add-btn">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><line x1="12" y1="5" x2="12" y2="19"></line><line
                        x1="5"
                        y1="12"
                        x2="19"
                        y2="12"></line></svg
                >
                {labels.addSubject}
            </button>
        </div>
    </div>

    <div id="subjects-list" class="subjects-list"></div>

    <div class="results-panel">
        <div class="result-label">{labels.finalGrade}</div>
        <div id="final-grade" class="result-value">0.00</div>

        <div class="weight-status-container">
            <div class="weight-progress-bar">
                <div id="weight-progress-fill" class="weight-progress-fill">
                </div>
            </div>
            <div
                id="weight-sum-warning"
                class="weight-warning"
                style="display: none;"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><circle cx="12" cy="12" r="10"></circle><line
                        x1="12"
                        y1="8"
                        x2="12"
                        y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"
                    ></line></svg
                >
                <span
                    >{labels.weightSum}: <span id="current-weight-sum">0</span
                    >%</span
                >
            </div>
        </div>
    </div>
</div>

<script is:inline define:vars={{ labels }}>
    const STORAGE_KEY = "jjlmoya_weighted_grades_v2";
    const SCALE_KEY = "jjlmoya_weighted_grades_scale";

    const subjectsList = document.getElementById("subjects-list");
    const addBtn = document.getElementById("add-subject");
    const scaleInput = document.getElementById("grade-scale");
    const finalGradeEl = document.getElementById("final-grade");
    const weightWarning = document.getElementById("weight-sum-warning");
    const weightSumEl = document.getElementById("current-weight-sum");
    const progressFill = document.getElementById("weight-progress-fill");

    let currentScale = 10;

    function saveState() {
        if (!subjectsList) return;
        const rows = subjectsList.querySelectorAll(".subject-row");
        const subjects = Array.from(rows).map((row) => {
            const nameEl = row.querySelector(".subject-name");
            const gradeEl = row.querySelector(".subject-grade");
            const weightEl = row.querySelector(".subject-weight");
            return {
                name: nameEl.value,
                grade: parseFloat(gradeEl.value) || 0,
                weight: parseFloat(weightEl.value) || 0,
                manual: row.hasAttribute("data-manual"),
            };
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(subjects));
        localStorage.setItem(SCALE_KEY, currentScale.toString());
    }

    function updateWeightStatus(totalWeight) {
        if (!weightWarning || !progressFill) return;

        progressFill.style.width = `${Math.min(totalWeight, 100)}%`;

        if (totalWeight > 100.1) {
            weightWarning.style.display = "flex";
            weightWarning.classList.add("error");
            progressFill.classList.add("error");
        } else if (Math.abs(totalWeight - 100) > 0.1 && totalWeight > 0) {
            weightWarning.style.display = "flex";
            weightWarning.classList.remove("error");
            progressFill.classList.add("warning");
        } else {
            weightWarning.style.display = totalWeight === 0 ? "none" : "flex";
            weightWarning.classList.remove("error");
            progressFill.classList.remove("error", "warning");
        }
    }

    function calculateGrade() {
        if (!subjectsList || !finalGradeEl || !weightSumEl) return;

        const rows = subjectsList.querySelectorAll(".subject-row");
        let totalWeightedGrade = 0;
        let totalWeight = 0;

        rows.forEach((row) => {
            const gradeInput = row.querySelector(".subject-grade");
            const weightInput = row.querySelector(".subject-weight");

            if (gradeInput && weightInput) {
                const grade = parseFloat(gradeInput.value) || 0;
                const weight = parseFloat(weightInput.value) || 0;

                totalWeightedGrade += grade * (weight / 100);
                totalWeight += weight;
            }
        });

        finalGradeEl.textContent = totalWeightedGrade.toFixed(2);
        weightSumEl.textContent = Math.round(totalWeight * 10) / 10 + "";

        updateWeightStatus(totalWeight);
        saveState();
    }

    function autoAdjustWeights() {
        if (!subjectsList) return;
        const rows = subjectsList.querySelectorAll(".subject-row");
        if (rows.length === 0) return;

        const manualRows = Array.from(rows).filter((r) =>
            r.hasAttribute("data-manual"),
        );
        const autoRows = Array.from(rows).filter(
            (r) => !r.hasAttribute("data-manual"),
        );

        let manualWeightTotal = 0;
        manualRows.forEach((row) => {
            const input = row.querySelector(".subject-weight");
            manualWeightTotal += parseFloat(input.value) || 0;
        });

        if (autoRows.length > 0) {
            const remainingWeight = Math.max(0, 100 - manualWeightTotal);
            const weightPerAuto = (remainingWeight / autoRows.length).toFixed(
                1,
            );
            autoRows.forEach((row) => {
                const input = row.querySelector(".subject-weight");
                input.value = weightPerAuto;
            });
        }
        calculateGrade();
    }

    function updateAllRowLabels() {
        if (!subjectsList) return;
        const rows = subjectsList.querySelectorAll(".subject-row");
        rows.forEach((row) => {
            const gradeLabel = row.querySelector(".grade-label");
            const gradeInput = row.querySelector(".subject-grade");
            if (gradeLabel)
                gradeLabel.textContent = `${labels.grade} (0-${currentScale})`;
            if (gradeInput) gradeInput.max = currentScale.toString();
        });
    }

    function createRowHTML(data) {
        const name = data?.name || "";
        const grade = data?.grade || 0;
        const weight = data?.weight || 0;

        return `
            <div class="input-group">
                <label class="input-label">${labels.subjectName}</label>
                <input type="text" class="input-control subject-name" placeholder="${labels.newSubjectPlaceholder}" value="${name}">
            </div>
            <div class="input-group">
                <label class="input-label grade-label">${labels.grade} (0-${currentScale})</label>
                <input type="number" class="input-control subject-grade" min="0" max="${currentScale}" step="any" value="${grade}">
            </div>
            <div class="input-group">
                <label class="input-label">${labels.weight}</label>
                <input type="number" class="input-control subject-weight" min="0" max="100" step="any" value="${weight}">
            </div>
            <button class="remove-btn" title="${labels.removeSubject}">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
            </button>
        `;
    }

    function attachRowListeners(row) {
        const weightInput = row.querySelector(".subject-weight");
        weightInput?.addEventListener("input", () => {
            row.setAttribute("data-manual", "true");
            calculateGrade();
        });

        row.querySelector(".subject-name")?.addEventListener(
            "input",
            calculateGrade,
        );
        row.querySelector(".subject-grade")?.addEventListener(
            "input",
            calculateGrade,
        );

        row.querySelector(".remove-btn")?.addEventListener("click", () => {
            row.remove();
            autoAdjustWeights();
        });
    }

    function addSubject(data) {
        if (!subjectsList) return;

        const row = document.createElement("div");
        row.className = "subject-row";
        if (data?.manual) {
            row.setAttribute("data-manual", "true");
        }

        row.innerHTML = createRowHTML(data);
        subjectsList.appendChild(row);
        attachRowListeners(row);

        if (!data) {
            autoAdjustWeights();
        }
    }

    function initFromStorage() {
        const savedScale = localStorage.getItem(SCALE_KEY);
        if (savedScale && scaleInput) {
            currentScale = parseFloat(savedScale) || 10;
            scaleInput.value = currentScale.toString();
        }

        const saved = localStorage.getItem(STORAGE_KEY);
        if (!saved || !subjectsList) return;

        subjectsList.innerHTML = "";
        const subjects = JSON.parse(saved);
        if (subjects.length > 0) {
            subjects.forEach((s) => addSubject(s));
            calculateGrade();
        } else {
            addSubject();
        }
    }

    function init() {
        if (!subjectsList || !addBtn || !scaleInput) return;

        initFromStorage();

        if (subjectsList.children.length === 0) {
            addSubject();
        }

        addBtn.addEventListener("click", () => addSubject());

        scaleInput.addEventListener("input", (e) => {
            const val = parseFloat(e.target.value);
            if (!isNaN(val) && val > 0) {
                currentScale = val;
                updateAllRowLabels();
                calculateGrade();
            }
        });
    }

    init();
</script>

<style>
    .weighted-calc-ui {
        --color-primary: #0ea5e9;
        --color-primary-dark: #0284c7;
        --color-accent: #6366f1;
        --color-success: #0ea5e9;
        --color-warning: #f59e0b;
        --color-error: #ef4444;
        --color-error-light: #fee2e2;
        --color-error-dark: #7f1d1d;
        --color-error-light-dark: #fca5a5;
        --color-error-bg: #dc2626;
        --color-text-light: #64748b;
        --color-text-dark: #0f172a;
        --color-border-light: #e2e8f0;
        --color-border-dark: #334155;
        --color-bg-light: rgba(255, 255, 255, 0.85);
        --color-bg-light-border: rgba(255, 255, 255, 0.5);
        --color-bg-light-shadow: rgba(14, 165, 233, 0.08);
        --color-row-light: rgba(255, 255, 255, 0.95);
        --color-row-light-border: rgba(0, 0, 0, 0.04);
        --color-row-light-shadow: rgba(0, 0, 0, 0.02);
        --color-progress-bar-light: #e2e8f0;
        --color-warning-light: #fef3c7;
        --color-focus-shadow: rgba(14, 165, 233, 0.15);
    }

    :global(.theme-dark) .weighted-calc-ui {
        --color-bg-light: #0f172a;
        --color-bg-light-border: #1e293b;
        --color-bg-light-shadow: rgba(0, 0, 0, 0.5);
        --color-row-light: #1e293b;
        --color-row-light-border: #334155;
        --color-row-light-shadow: rgba(0, 0, 0, 0.3);
        --color-progress-bar-light: #0f172a;
        --color-warning-light: #1e293b;
        --color-text-light: #94a3b8;
    }

    .weighted-calc-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem;
        border-radius: 2rem;
        background: var(--color-bg-light);
        backdrop-filter: blur(10px);
        border: 1px solid var(--color-bg-light-border);
        box-shadow: 0 20px 40px var(--color-bg-light-shadow);
        transition: all 0.3s ease;
    }

    .calc-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        gap: 2rem;
    }

    .header-actions {
        display: flex;
        align-items: flex-end;
        gap: 1.5rem;
    }

    .scale-setting {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 150px;
    }

    .calc-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--slate-900);
    }

    :global(.dark) .calc-title {
        color: var(--color-success);
    }

    .subjects-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .subject-row {
        display: grid;
        grid-template-columns: 1fr 100px 100px 40px;
        gap: 1rem;
        align-items: center;
        padding: 1rem;
        border-radius: 1rem;
        background: var(--color-row-light);
        border: 1px solid var(--color-row-light-border);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .subject-row:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px var(--color-row-light-shadow);
    }

    .input-group {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .input-label {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-text-light);
    }

    .input-control {
        width: 100%;
        padding: 0.75rem;
        border-radius: 0.5rem;
        border: 1px solid var(--color-border-light);
        background: #fff;
        font-size: 1rem;
        transition: border-color 0.2s ease, ring 0.2s ease;
    }

    :global(.dark) .input-control {
        background: var(--color-text-dark);
        border-color: var(--color-border-dark);
        color: var(--color-success);
    }

    .input-control:focus {
        outline: none;
        border-color: var(--color-primary);
        box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.2);
    }

    .remove-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--color-error-light);
        color: var(--color-error);
        border: none;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.2s ease;
        margin-top: 1.25rem;
    }

    :global(.dark) .remove-btn {
        background: var(--color-error-dark);
        color: var(--color-error-light-dark);
    }

    .remove-btn:hover {
        background: #fecaca;
        transform: scale(1.1);
    }

    .add-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 1rem;
        background: var(--color-primary);
        color: var(--color-success);
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: background 0.2s ease, transform 0.2s ease;
        margin: 0 auto;
    }

    .add-btn:hover {
        background: var(--color-primary-dark);
        transform: translateY(-2px);
    }

    .results-panel {
        margin-top: 3rem;
        padding: 2.5rem;
        border-radius: 2rem;
        color: var(--color-success);
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .results-panel::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
        pointer-events: none;
    }

    .result-label {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        opacity: 0.9;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .result-value {
        font-size: 5rem;
        font-weight: 900;
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 1rem;
        text-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    }

    .weight-status-container {
        margin-top: 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
    }

    .weight-progress-bar {
        width: 100%;
        height: 8px;
        background: var(--color-progress-bar-light);
        border-radius: 4px;
        overflow: hidden;
    }

    .weight-progress-fill {
        height: 100%;
        background: var(--color-success);
        width: 0%;
        transition: width 0.3s ease, background-color 0.3s ease;
    }

    .weight-progress-fill.error {
        background: #f87171;
    }

    .weight-progress-fill.warning {
        background: var(--color-warning);
    }

    .weight-warning {
        font-size: 0.875rem;
        font-weight: 700;
        padding: 0.625rem 1.25rem;
        border-radius: 1rem;
        background: var(--color-warning-light);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        backdrop-filter: blur(5px);
        animation: pulse 2s infinite;
    }

    @keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.02);
        }

        100% {
            transform: scale(1);
        }
    }

    .weight-warning.error {
        background: var(--color-error-dark);
        color: var(--color-error-light-dark);
    }

    @keyframes view-fade-in {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .view-fade-in {
        animation: view-fade-in 0.6s ease forwards;
    }

    @media (max-width: 640px) {
        .calc-header {
            flex-direction: column;
            align-items: stretch;
            gap: 1.5rem;
        }

        .header-actions {
            flex-direction: column;
            align-items: stretch;
            gap: 1rem;
        }

        .subject-row {
            grid-template-columns: 1fr;
            gap: 0.75rem;
        }

        .remove-btn {
            width: 100%;
            margin-top: 0;
            border-radius: 0.5rem;
        }

        .input-group:nth-child(2),
        .input-group:nth-child(3) {
            grid-row: auto;
        }
    }
</style>
