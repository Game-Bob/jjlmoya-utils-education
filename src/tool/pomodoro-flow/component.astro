---
import type { PomodoroFlowUI } from "./index";
import { CYCLE_PRESETS } from "./logic";

interface Props {
  ui?: Partial<PomodoroFlowUI>;
}

const { ui = {} } = Astro.props;
const labels = {
  taskInput: ui.taskInput || "What are you going to work on?",
  selectCycle: ui.selectCycle || "Choose your focus cycle",
  startButton: ui.startButton || "Start",
  seed: ui.seed || "Seed",
  tree: ui.tree || "Tree",
  mountain: ui.mountain || "Mountain",
  timer: ui.timer || "Timer",
  pauseButton: ui.pauseButton || "Pause",
  resumeButton: ui.resumeButton || "Resume",
  distractionButton: ui.distractionButton || "Distraction",
  addFiveMin: ui.addFiveMin || "+5m",
  subtractFiveMin: ui.subtractFiveMin || "-5m",
  focusMode: ui.focusMode || "Focus",
  breakTime: ui.breakTime || "Break",
  focusScore: ui.focusScore || "Focus Score",
  totalTime: ui.totalTime || "Total Time",
  interruptions: ui.interruptions || "Interruptions",
  taskBreakdown: ui.taskBreakdown || "Task Breakdown",
  monthlyHeatmap: ui.monthlyHeatmap || "Monthly Activity",
  copyMarkdown: ui.copyMarkdown || "Copy Markdown",
  shareImage: ui.shareImage || "Share",
  wellnessMessage: ui.wellnessMessage || "Take a break, you deserve it",
  sessionSummary: ui.sessionSummary || "Session Summary",
  newSession: ui.newSession || "New Session",
  copied: ui.copied || "Copied!",
  unnamedTask: ui.unnamedTask || "Unnamed Task",
  breakTimeNotification: ui.breakTimeNotification || "Break time!",
  focusTimeNotification: ui.focusTimeNotification || "Time to focus!",
  interruptionsLabel: ui.interruptionsLabel || "Interruptions:",
  studySession: ui.studySession || "Study Session",
};
---

<div class="pomodoro-ui pomodoro-container view-fade-in">
  <div class="pomodoro-phase active" id="phase-config">
    <div class="phase-config">
      <div class="task-input-wrapper">
        <input
          type="text"
          class="task-input"
          id="task-input"
          placeholder={labels.taskInput}
          autofocus
        />
      </div>

      <div style="width: 100%;">
        <div style="margin-bottom: 1.5rem; font-size: 0.85rem; color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">
          {labels.selectCycle}
        </div>
        <div class="cycle-selector">
          {Object.entries(CYCLE_PRESETS).map(([key, preset]) => (
            <div
              class="cycle-card"
              data-cycle={key}
              data-work={preset.work}
              data-break={preset.break}
            >
              <div class="cycle-name">{preset.label}</div>
              <div class="cycle-duration">
                {preset.work}m / {preset.break}m
              </div>
            </div>
          ))}
        </div>
      </div>

      <button class="start-button" id="start-btn">
        {labels.startButton}
      </button>
    </div>
  </div>

  <div class="pomodoro-phase" id="phase-flow">
    <div class="phase-flow">
      <div class="task-name-display" id="task-name"></div>

      <div class="timer-container">
        <div class="timer-label" id="phase-label">Focus</div>

        <div class="timer-ring" id="timer-ring">
          <svg class="timer-ring-svg" viewBox="0 0 300 300">
            <circle
              cx="150"
              cy="150"
              r="140"
              fill="none"
              stroke="currentColor"
              stroke-width="8"
              style="opacity: 0.2;"
            />
            <circle
              id="progress-ring"
              cx="150"
              cy="150"
              r="140"
              fill="none"
              stroke="currentColor"
              stroke-width="8"
              stroke-dasharray="879.6"
              stroke-dashoffset="879.6"
              stroke-linecap="round"
              transform="rotate(-90 150 150)"
              style="transition: stroke-dashoffset 1s linear; color: var(--color-focus);"
            />
          </svg>
          <div class="timer-display" id="timer-display">25:00</div>
        </div>

        <div class="timer-controls">
          <button class="timer-btn" id="minus-5">
            {labels.subtractFiveMin}
          </button>
          <button class="timer-btn" id="pause-btn">
            {labels.pauseButton}
          </button>
          <button class="timer-btn" id="plus-5">
            {labels.addFiveMin}
          </button>
        </div>

        <div style="display: flex; gap: 1rem; align-items: center; justify-content: center; flex-wrap: wrap;">
          <button class="distraction-btn" id="distraction-btn">
            {labels.distractionButton}
          </button>
          <div style="font-size: 0.9rem; color: var(--color-text-secondary);">
            {labels.interruptionsLabel} <span id="interrupt-count" style="font-weight: 700; color: var(--color-break);">0</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="pomodoro-phase" id="phase-harvest">
    <div class="phase-harvest">
      <div class="harvest-title">{labels.sessionSummary}</div>

      <div class="harvest-grid">
        <div class="harvest-card">
          <div class="harvest-card-label">{labels.focusScore}</div>
          <div class="harvest-card-value" id="harvest-focus">95%</div>
        </div>
        <div class="harvest-card">
          <div class="harvest-card-label">{labels.totalTime}</div>
          <div class="harvest-card-value" id="harvest-time">50m</div>
        </div>
        <div class="harvest-card">
          <div class="harvest-card-label">{labels.interruptions}</div>
          <div class="harvest-card-value" id="harvest-interruptions">0</div>
        </div>
        <div class="harvest-card">
          <div class="harvest-card-label">{labels.taskBreakdown}</div>
          <div class="harvest-card-value" id="harvest-tasks">1</div>
        </div>
      </div>

      <div class="charts-container">
        <div class="chart-wrapper">
          <div class="chart-title">{labels.taskBreakdown}</div>
          <div id="task-breakdown" style="display: flex; flex-direction: column; gap: 0.75rem;"></div>
        </div>
      </div>

      <div class="harvest-actions">
        <button class="action-btn" id="copy-markdown">
          {labels.copyMarkdown}
        </button>
        <button class="action-btn" id="new-session-btn">
          {labels.newSession}
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ labels }}>
  window.pomodoroLabels = labels;
</script>

<script>
  import { initPomodoroTimer } from './script';

  const { init } = initPomodoroTimer(window.pomodoroLabels);

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

